<h1>
    <%= title %>
</h1>
<div class="register-container">
    <!-- FLASH MESSAGE -->
    <%- messages() %>

    <!--  Display Errors -->
    <% if (errors && !errors.isEmpty()) { %>
        <ul class="notice">
     <% errors.array().forEach(error=> { %>
            <li><%= error.msg %></li>
     <% }) %>
       </ul>
    <% } %>
    
    <!-- REGISTER FORM -->
     <form action="/account/register" method="post" class="register-form">
        <label>First name
            <input type="text" name="account_firstname" id="accountfirstname" required value="<%= locals.account_firstname %>">
        </label>
        <label>Last name
            <input type="text" name="account_lastname" id="accountlastname" required value="<%= locals.account_lastname %>">
        </label>
        <label>Email address
            <input type="email" name="account_email" id="accountemail" placeholder="Please enter a valid email" required value="<%= locals.account_email %>">
        </label>
        <p>
            Password must be:<br>
            ✅12 characters in length, minimum<br>
            ✅contain at least 1 capital letter<br>
            ✅contain at least 1 number<br>
            ✅contain at least 1 special letter<br>
        </p>
        <label>Password
            <input type="password" name="account_password" id="password" required 
            pattern="^(?=.*\d)(?=.*[a-z])(?=.*[A-Z])(?=.*[^a-zA-Z0-9])(?!.*\s).{12,}$">
        </label>
        
        <button class="register-btn">Register</button>
     </form>
</div>