<h1>
    <%= title %>
</h1>
<div class="account-update-view">
    <%- messages() %>

    <h2>Update Account Information</h2>
    <form action="/account/update-view" method="post" id="updateAccountForm">
        <input type="hidden" name="account_id" value="<%= accountData.account_id %>">
        <label for="account_firstname">First Name:
                <input type="text" id="account_firstname" name="account_firstname" value="<%= accountData.account_firstname %>"
                required>
        </label>
    
        <label for="account_lastname">Last Name:
            <input type="text" id="account_lastname" name="account_lastname" value="<%= accountData.account_lastname %>" required>
        </label>
    
        <label for="account_email">Email:
            <input type="email" id="account_email" name="account_email" value="<%= accountData.account_email %>" required>
        </label>
        
        <button type="submit">Update Account</button>
    </form>
    <form action="/account/update-password" method="post" id="updatePasswordForm">
        <p>
            Password must be:<br>
            ✅12 characters in length, minimum<br>
            ✅contain at least 1 capital letter<br>
            ✅contain at least 1 number<br>
            ✅contain at least 1 special letter<br>
            ❗Original password will be changed
        </p>
        <label for="account_password">Password:
            <input type="password" id="account_password" name="account_password" pattern="^(?=.*\d)(?=.*[a-z])(?=.*[A-Z])(?=.*[^a-zA-Z0-9])(?!.*\s).{12,}$">
        </label>
        <input type="hidden" name="account_id" value="<%= accountData.account_id %>">
        <button type="submit">Update Password</button>
    </form>
</div>