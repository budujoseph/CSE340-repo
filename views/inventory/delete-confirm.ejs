<h1>
    <%- title %>
</h1>

<div class="add-inventory-container">
    <%- messages() %>

    <!--  Display Errors -->
    <% if (errors && !errors.isEmpty()) { %>
        <ul class="notice">
            <% errors.array().forEach(error=> { %>
                <li>
                    <%= error.msg %>
                </li>
            <% }) %>
        </ul>
    <% } %>

    <form action="/inv/delete" method="post" class="inventory-form">
        <p>Confirm deletion - The delete is permanent</p>
        <label>Make
            <input type="text" name="inv_make" required value="<%= locals.inv_make %>" placeholder="Min of 3 characters" minlength="3" readonly>
        </label>

        <label>Model
            <input type="text" name="inv_model" required value="<%= locals.inv_model %>" placeholder="Min of 3 characters" minlength="3" readonly>
        </label>

        <label>Year
            <input type="number" name="inv_year" required value="<%= locals.inv_year %>" placeholder="4-digit year" readonly>
        </label>
        <label>Price
            <input type="number" name="inv_price" required value="<%= locals.inv_price %>" min="0" placeholder="decimal or integer" readonly>
        </label>
       
        <button type="submit">Delete Vehicle</button>

    <input type="hidden" name="inv_id" 
    <% if(locals.inv_id) { %> value="<%= locals.inv_id %>"
    <% } %>>
    </form>

</div>