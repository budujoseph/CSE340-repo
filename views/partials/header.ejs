<header id="top-header">
    <span class="siteName">
        <a href="/" title="Return to home page">CSE Motors</a>
    </span>
    <div id="tools">
        <% if (loggedin) { %>
            <a href="/account/" title="Manage your account">
                Welcome <%= accountData.account_firstname %>
            </a>
            <a href="/account/logout" title="Logout of your account">Logout</a>
        <% } else { %>
            <a href="/account/login" title="Click to log in">MY ACCOUNT</a>
        <% } %>
    </div>
</header>